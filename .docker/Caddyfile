{
    admin off
    auto_https off
    storage /var/www/html/storage/caddy
}

:80 {
    root * /var/www/html/public
    encode gzip

    request_body {
        max_size 210MB
    }

    try_files {path} {path}/ /index.php?{query}

    php_fastcgi 127.0.0.1:9000 {
        root /var/www/html/public
    }

    file_server
}
